# Rename this file to .env and adapt it to your needs.
# NEVER commit .env — it exposes your passwords. Use secrets in CI (e.g. GitHub secrets).

######### SERVER CONFIGURATION #########
GOELAND_LISTEN_ADDRESS=127.0.0.1:8080
GOELAND_SHUTDOWN_TIMEOUT_SECONDS=10
GOELAND_REQUEST_TIMEOUT_SECONDS=10

######### DATABASE CONFIGURATION #########
# PostgreSQL 14+ with the PostGIS, pgcrypto, pg_trgm and unaccent extensions available.
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=goeland_poc_db
DB_USER=goeland_poc_db
DB_PASSWORD=Choose_your_own_password_here
DB_SSL_MODE=prefer
DATABASE_URL=postgres://goeland_poc_db:Choose_your_own_password_here@127.0.0.1:5432/goeland_poc_db?sslmode=prefer
GOELAND_DB_MAX_CONNECTIONS=10

######### AUTHENTICATION #########
# jwt: verify tokens issued by go-cloud-k8s-auth (JWT settings below) + introspect PATs (pat_...).
# dev: accept GOELAND_DEV_TOKEN for one explicit local development user.
GOELAND_AUTH_MODE=dev
AUTH_SERVER_URL=http://localhost:9090
GOELAND_DEV_TOKEN=dev-local-token
GOELAND_DEV_USER_ID=1
GOELAND_DEV_USER_EMAIL=dev@localhost
GOELAND_DEV_USER_NAME=Local Goeland User

######### JSON WEB TOKEN CONFIGURATION (jwt mode) #########
JWT_SECRET="Use your nice and complicated secret here"
JWT_ISSUER_ID=2490AD68-3AA9-4C17-BB49-33C2F202B754
JWT_CONTEXT_KEY=goelandContextKey
JWT_DURATION_MINUTES=15
JWT_AUTH_URL=/login
JWT_STATUS_URL=/status

######### LOG CONFIGURATION #########
# LOG_LEVEL: debug, info, warn, error
LOG_LEVEL=info
